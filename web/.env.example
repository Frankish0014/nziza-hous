# Copy to .env.local for local development.
#
# Vercel: In the project Settings → General, set "Root Directory" to `web` (this folder). Then add the variables below under Settings → Environment Variables (Production / Preview as needed).
#
# Dev only: visiting via phone/LAN IP? Add it (comma-separated) to silence Next.js cross-origin /_next warnings — e.g. NEXT_DEV_EXTRA_ORIGINS=172.20.10.4


# --- Database (Vercel Postgres / Neon / local) — pick one URL style ---
# POSTGRES_URL=
# DATABASE_URL=

# Catalog-only: skip DB init and serve services from data/catalog.fallback.json (bookings/auth still need Postgres)
# CATALOG_SOURCE=json

# --- Auth (required in production; use a long random string) ---
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# --- Optional admin bootstrap (first deploy / dev) ---
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NAME=Platform Admin

# --- Email (contact form on Vercel: set SMTP below if you have no Postgres yet — messages are emailed to ADMIN_NOTIFICATION_EMAIL and a thank-you is sent to the visitor) ---
# Next.js also loads ../backend/.env and ../.env so you can keep SMTP next to the Express backend.
# Use a Gmail App Password for SMTP_PASS (2FA required): https://myaccount.google.com/apppasswords
# FROM_EMAIL must match SMTP_USER for Gmail (or a verified Google Workspace alias); otherwise delivery often fails.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=
# Admin receives new-booking alerts with a link to /admin/bookings (set SITE_URL for the button to work).
# ADMIN_NOTIFICATION_EMAIL=nzizahousetd@gmail.com
# SITE_URL=http://localhost:3000
# BOOKING_TIMEZONE=Africa/Kigali

# --- URLs ---
# Leave NEXT_PUBLIC_API_URL unset: the app always uses same-origin /api in the browser.
# (An old value like http://localhost:4000/api pointed at Express and breaks `npm run dev:web`.)
# PUBLIC_BASE_URL=https://your-domain.com

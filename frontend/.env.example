# Must live in frontend/ (project root next to package.json), NOT in src/
VITE_API_URL=http://localhost:4000/api

# ─── No API yet (Vercel / static catalog) ──────────────────────────────────
# Set only on the host — do NOT use localhost in production.
#   VITE_USE_STATIC_CATALOG=true
# Services + booking *availability UI* load from public/catalog.json (edit & redeploy to change).
# Submitting bookings, contact form, auth, and admin still need a real API + VITE_API_URL later.

# ─── Production (Vercel) ───────────────────────────────────────────────────
# Project root is the Git repo (see vercel.json: build uses npm workspaces → frontend/dist).
# When the backend is live, set VITE_API_URL to your public API, e.g.
#   https://your-api.example.com/api
# Remove or set VITE_USE_STATIC_CATALOG=false when switching to the API.
# Never set VITE_API_URL=http://localhost:4000/api on Vercel — that points at each visitor's PC.
#
# Optional: proxy same-origin /api without VITE_API_URL — add a rewrite *before* the SPA rule in vercel.json:
#   { "source": "/api/:path*", "destination": "https://your-api.example.com/api/:path*" }
#
# ─── Netlify (if used) ──────────────────────────────────────────────────────
# Site → Environment variables: same VITE_API_URL, or netlify.toml redirects — see netlify.toml.

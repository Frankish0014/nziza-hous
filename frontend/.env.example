# Must live in frontend/ (project root next to package.json), NOT in src/
VITE_API_URL=http://localhost:4000/api

# Netlify (production): set the same variable in Site → Environment variables
# to your *public* API URL, e.g. https://your-app.onrender.com/api — then trigger a rebuild.
# Do not use localhost; the browser runs on visitors' machines, not your server.

# Must live in frontend/ (project root next to package.json), NOT in src/
VITE_API_URL=http://localhost:4000/api

# Netlify (production): set the same variable in Site → Environment variables
# to your *public* API base URL (any host: Railway, Fly.io, VPS, Cloud Run, etc.), e.g.
#   https://api.yourdomain.com/api
# then trigger a rebuild. Do not use localhost in production.

# Must live in frontend/ (project root next to package.json), NOT in src/
VITE_API_URL=http://localhost:4000/api

# ─── No API yet (static catalog) ─────────────────────────────────────────────
# Set only on the host — do NOT use localhost in production.
#   VITE_USE_STATIC_CATALOG=true
# Services + booking *availability UI* load from public/catalog.json (edit & redeploy to change).
# Submitting bookings, contact form, auth, and admin still need a real API + VITE_API_URL later.

# ─── Production (Netlify) ──────────────────────────────────────────────────
# Repo root holds netlify.toml (build + SPA + optional /api redirects). Publish `frontend/dist` output.
# When the backend is live, set VITE_API_URL at build time to your public API, e.g.
#   https://your-api.example.com/api
# Remove or set VITE_USE_STATIC_CATALOG=false when switching to the API.
# Never set VITE_API_URL=http://localhost:4000/api in Netlify prod — browsers would still call localhost for each visitor.
#
# Recommended for Netlify: set NETLIFY_API_ORIGIN (repo root) on the site to your API origin only, e.g.
#   https://your-api.onrender.com
# The build runs scripts/netlify-prebuild.mjs and writes frontend/public/_redirects so /api/* proxies to Express.

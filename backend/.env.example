PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# PostgreSQL — use EITHER DATABASE_URL (Neon/Supabase/Railway) OR the variables below.

# DATABASE_URL=postgresql://user:pass@ep-xxxxx.neon.tech/neondb?sslmode=require
# (The API appends uselibpqcompat=true when missing — silences Node SSL mode warnings with pg 8.x.)

# Local / discrete vars:
# Use 127.0.0.1 if localhost / IPv6 causes ECONNREFUSED with Docker Postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nziza_house

# Optional: startup retries in development (~60s total wait for Postgres)
# DB_CONNECT_RETRIES=30
# DB_CONNECT_DELAY_MS=2000

# Optional: public URL of this API (no trailing slash) — correct links for uploaded files behind a proxy
# PUBLIC_BASE_URL=http://localhost:4000
# Trust X-Forwarded-* headers (set true behind nginx/Render/Railway)
# TRUST_PROXY=true

# Comma-separated browser origins, or * — restrict in production (e.g. https://yourapp.com,https://www.yourapp.com)
# CORS_ORIGIN=http://localhost:5173

# One-time admin user (created only if email does not exist yet)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-immediately
# SEED_ADMIN_NAME=Platform Admin

FROM_EMAIL=no-reply@nzizahouse.com
ADMIN_NOTIFICATION_EMAIL=bookings@nzizahouse.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

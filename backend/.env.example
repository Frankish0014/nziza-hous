PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# PostgreSQL — connection string resolution is in src/config/pickDatabaseUrl.js
#
# Production (typical): POSTGRES_URL — e.g. Vercel Postgres injects this; the app uses `pg` (no @vercel/postgres client).
# Local: prefer LOCAL_POSTGRES_URL or DATABASE_URL so dev wins over a copied POSTGRES_URL.
#
# POSTGRES_URL=postgresql://...
# LOCAL_POSTGRES_URL=postgresql://...
# DATABASE_URL=postgresql://user:pass@ep-xxxxx.neon.tech/neondb?sslmode=require
# (The API appends uselibpqcompat=true when missing — silences Node SSL mode warnings with pg 8.x.)
#
# Optional: serve only the public services catalog from disk (no Postgres on boot). Bookings/auth/admin still need a DB.
# CATALOG_SOURCE=json

# Local / discrete vars:
# Use 127.0.0.1 if localhost / IPv6 causes ECONNREFUSED with Docker Postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nziza_house

# Optional: startup retries in development (~60s total wait for Postgres)
# DB_CONNECT_RETRIES=30
# DB_CONNECT_DELAY_MS=2000

# Optional: public URL of this API (no trailing slash) — correct links for uploaded files behind a proxy
# PUBLIC_BASE_URL=http://localhost:4000
# Trust X-Forwarded-* headers (set true behind nginx, a load balancer, or a PaaS)
# TRUST_PROXY=true

# Comma-separated browser origins, or * — restrict in production (e.g. https://yourapp.com,https://www.yourapp.com)
# CORS_ORIGIN=http://localhost:5173

# One-time admin user (created only if email does not exist yet)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-immediately
# SEED_ADMIN_NAME=Platform Admin

# Gmail: FROM_EMAIL should match SMTP_USER (this inbox), or Google may reject mail after login succeeds.
# Use a 16-character App Password — not your normal Gmail password:
# https://myaccount.google.com/apppasswords (requires 2-Step Verification on the Google account)
FROM_EMAIL=nzizahousetd@gmail.com
ADMIN_NOTIFICATION_EMAIL=bookings@nzizahouse.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nzizahousetd@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

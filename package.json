{
  "name": "nziza-house-workspace",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "web"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "db:up": "node scripts/db-up.mjs",
    "db:down": "node scripts/db-down.mjs",
    "db:logs": "node scripts/db-logs.mjs",
    "dev:legacy": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:all": "npm run dev:legacy",
    "dev:web": "npm run dev -w web",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "db:check": "npm run db:check --prefix backend",
    "build": "npm run build -w web",
    "build:frontend": "npm run build -w frontend",
    "lint": "npm run lint -w web",
    "lint:frontend": "npm run lint -w frontend",
    "start:web": "npm run start -w web",
    "preview:web": "npm run build -w web && npm run start -w web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}

